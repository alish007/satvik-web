// ============================================
// Satvik Platform — Prisma Schema
// Database: Supabase (PostgreSQL)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  CUSTOMER
  ADMIN
  DELIVERY_PARTNER
}

enum LoyaltyTier {
  GREEN
  FRESH
  ORGANIC
  ELITE
}

enum OrderType {
  INSTANT
  SCHEDULED
}

enum OrderStatus {
  PLACED
  PREPARING
  PACKED
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum SubscriptionPlan {
  DAILY
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  COD
  BNPL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum VehicleType {
  BICYCLE
  EBIKE
  MOTORCYCLE
}

enum ContactType {
  GENERAL
  WHOLESALE
  NEWSLETTER
}

enum DeliverySlot {
  EARLY_MORNING
  MORNING
  MIDDAY
  AFTERNOON
  EVENING
}

// ============================================
// MODELS
// ============================================

/// Users — customers, admins, and delivery partners
model User {
  id                  String    @id @default(cuid())
  supabaseAuthId      String?   @unique @map("supabase_auth_id")
  phone               String?   @unique
  email               String?   @unique
  name                String?
  avatarUrl           String?   @map("avatar_url")
  role                UserRole  @default(CUSTOMER)
  dietaryPreferences  Json?     @map("dietary_preferences")
  loyaltyTier         LoyaltyTier @default(GREEN) @map("loyalty_tier")
  satvikCoins         Int       @default(0) @map("satvik_coins")
  referralCode        String?   @unique @map("referral_code")
  referredBy          String?   @map("referred_by")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  addresses           Address[]
  cartItems           CartItem[]
  wishlists           Wishlist[]
  orders              Order[]
  subscriptions       Subscription[]
  reviews             Review[]
  payments            Payment[]
  notifications       Notification[]
  deliveryPartner     DeliveryPartner?

  @@map("users")
}

/// Delivery addresses
model Address {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  label       String   @default("Home")
  fullAddress String   @map("full_address")
  landmark    String?
  city        String   @default("Surat")
  state       String   @default("Gujarat")
  pincode     String
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  subscriptions Subscription[]

  @@map("addresses")
}

/// Product categories
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  emoji       String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products    Product[]

  @@map("categories")
}

/// Products — juices, vegetables, shots, bundles
model Product {
  id                String   @id @default(cuid())
  categoryId        String   @map("category_id")
  name              String
  slug              String   @unique
  description       String?
  shortDescription  String?  @map("short_description")
  price             Float
  subscriptionPrice Float?   @map("subscription_price")
  size              String?
  emoji             String?
  color             String?
  imageUrl          String?  @map("image_url")
  ingredients       Json?
  nutritionalInfo   Json?    @map("nutritional_info")
  benefits          Json?
  allergenInfo      String?  @map("allergen_info")
  farmOrigin        String?  @map("farm_origin")
  badge             String?
  stockQty          Int      @default(100) @map("stock_qty")
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  category          Category @relation(fields: [categoryId], references: [id])
  cartItems         CartItem[]
  wishlists         Wishlist[]
  orderItems        OrderItem[]
  subscriptionItems SubscriptionItem[]
  reviews           Review[]

  @@map("products")
}

/// Shopping cart items
model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

/// Wishlist / saved items
model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

/// Orders — instant and scheduled
model Order {
  id                  String      @id @default(cuid())
  userId              String      @map("user_id")
  addressId           String      @map("address_id")
  couponId            String?     @map("coupon_id")
  deliveryPartnerId   String?     @map("delivery_partner_id")
  orderNumber         String      @unique @map("order_number")
  type                OrderType   @default(INSTANT)
  status              OrderStatus @default(PLACED)
  subtotal            Float
  deliveryFee         Float       @default(0) @map("delivery_fee")
  discount            Float       @default(0)
  tax                 Float       @default(0)
  total               Float
  deliverySlot        DeliverySlot? @map("delivery_slot")
  specialInstructions String?     @map("special_instructions")
  deliveryProofUrl    String?     @map("delivery_proof_url")
  estimatedDelivery   DateTime?   @map("estimated_delivery")
  deliveredAt         DateTime?   @map("delivered_at")
  cancelledAt         DateTime?   @map("cancelled_at")
  cancelReason        String?     @map("cancel_reason")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  user                User        @relation(fields: [userId], references: [id])
  address             Address     @relation(fields: [addressId], references: [id])
  coupon              Coupon?     @relation(fields: [couponId], references: [id])
  deliveryPartner     DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  items               OrderItem[]
  payment             Payment?
  reviews             Review[]

  @@map("orders")
}

/// Items within an order
model OrderItem {
  id         String  @id @default(cuid())
  orderId    String  @map("order_id")
  productId  String  @map("product_id")
  quantity   Int
  unitPrice  Float   @map("unit_price")
  totalPrice Float   @map("total_price")

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Subscriptions — daily, weekly, monthly plans
model Subscription {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  addressId       String             @map("address_id")
  planType        SubscriptionPlan   @map("plan_type")
  deliverySlot    DeliverySlot       @map("delivery_slot")
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @map("start_date")
  endDate         DateTime?          @map("end_date")
  nextDelivery    DateTime?          @map("next_delivery")
  pauseFrom       DateTime?          @map("pause_from")
  pauseUntil      DateTime?          @map("pause_until")
  autoRenew       Boolean            @default(true) @map("auto_renew")
  discountPercent Float              @default(0) @map("discount_percent")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user            User               @relation(fields: [userId], references: [id])
  address         Address            @relation(fields: [addressId], references: [id])
  items           SubscriptionItem[]

  @@map("subscriptions")
}

/// Products within a subscription
model SubscriptionItem {
  id              String       @id @default(cuid())
  subscriptionId  String       @map("subscription_id")
  productId       String       @map("product_id")
  quantity        Int          @default(1)
  dayOfWeek       Int?         @map("day_of_week")

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id])

  @@map("subscription_items")
}

/// Payment records
model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique @map("order_id")
  userId          String        @map("user_id")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Float
  transactionId   String?       @unique @map("transaction_id")
  gatewayResponse Json?         @map("gateway_response")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order           Order         @relation(fields: [orderId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@map("payments")
}

/// Product reviews and ratings
model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  orderId   String?  @map("order_id")
  rating    Int
  comment   String?
  photoUrls Json?    @map("photo_urls")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id])

  @@map("reviews")
}

/// Coupons and promo codes
model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Float        @map("discount_value")
  minOrderValue Float?       @map("min_order_value")
  maxDiscount   Float?       @map("max_discount")
  usageLimit    Int?         @map("usage_limit")
  usedCount     Int          @default(0) @map("used_count")
  validFrom     DateTime     @map("valid_from")
  validUntil    DateTime     @map("valid_until")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")

  orders        Order[]

  @@map("coupons")
}

/// Delivery partner profiles
model DeliveryPartner {
  id              String      @id @default(cuid())
  userId          String      @unique @map("user_id")
  vehicleType     VehicleType @map("vehicle_type")
  idProofUrl      String?     @map("id_proof_url")
  licenseUrl      String?     @map("license_url")
  vehicleNumber   String?     @map("vehicle_number")
  bankAccount     Json?       @map("bank_account")
  isVerified      Boolean     @default(false) @map("is_verified")
  isOnline        Boolean     @default(false) @map("is_online")
  zone            String?
  currentLat      Float?      @map("current_lat")
  currentLng      Float?      @map("current_lng")
  totalDeliveries Int         @default(0) @map("total_deliveries")
  avgRating       Float       @default(0) @map("avg_rating")
  totalEarnings   Float       @default(0) @map("total_earnings")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User        @relation(fields: [userId], references: [id])
  orders          Order[]

  @@map("delivery_partners")
}

/// Notifications
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

/// Contact form submissions and newsletter signups
model ContactSubmission {
  id         String      @id @default(cuid())
  name       String?
  email      String
  phone      String?
  type       ContactType @default(GENERAL)
  message    String?
  isResolved Boolean     @default(false) @map("is_resolved")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@map("contact_submissions")
}

/// Blog categories
model BlogCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")

  posts       BlogPost[]

  @@map("blog_categories")
}

/// Blog posts
model BlogPost {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  emoji       String?
  author      String   @default("Satvik Team")
  readTime    String   @map("read_time")
  date        String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category    BlogCategory @relation(fields: [categoryId], references: [id])

  @@map("blog_posts")
}

